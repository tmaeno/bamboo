#compdef bamboo

_bamboo() {
  local state

  _arguments \
    '1: :->command' \
    '*: :->args'

  case $state in
    command)
      local commands
      commands=(
        'interactive:Start interactive mode'
        'populate:Populate knowledge base from various sources'
        'extract:Extract knowledge graph and preview without writing to databases'
        'analyze:Analyze a problematic task and generate a resolution'
        'fetch-task:Fetch task details from PanDA'
        'verify:Verify that the Bamboo package is correctly installed'
      )
      _describe 'bamboo command' commands
      ;;
    args)
      case $words[2] in
        populate)
          _arguments \
            '--email-thread[Path to email thread text file]:file:_files' \
            '--task-data[Path to task data JSON file]:file:_files' \
            '--task-id[PanDA jediTaskID]:task id' \
            '--external-data[Path to external data JSON file]:file:_files' \
            '--help[Show help]'
          ;;
        extract)
          _arguments \
            '--email-thread[Path to email thread text file]:file:_files' \
            '--task-data[Path to task data JSON file]:file:_files' \
            '--task-id[PanDA jediTaskID]:task id' \
            '--external-data[Path to external data JSON file]:file:_files' \
            '(-o --output)'{-o,--output}'[Save extracted graph as JSON]:file:_files' \
            '--help[Show help]'
          ;;
        analyze)
          _arguments \
            '--task-data[Path to task data JSON file]:file:_files' \
            '--task-id[PanDA jediTaskID]:task id' \
            '--external-data[Path to external data JSON file]:file:_files' \
            '--output[Path to save analysis results]:file:_files' \
            '--help[Show help]'
          ;;
        fetch-task)
          _arguments \
            '1:task id' \
            '(-o --output)'{-o,--output}'[Save task data as JSON]:file:_files' \
            '(-v --verbose)'{-v,--verbose}'[Print verbose communication logs]' \
            '--help[Show help]'
          ;;
        interactive|verify)
          _arguments '--help[Show help]'
          ;;
      esac
      ;;
  esac
}

_bamboo "$@"

