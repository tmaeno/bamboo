# LLM Configuration
# OpenAI or Anthropic key — not required when LLM_PROVIDER=ollama
LLM_API_KEY=your_api_key_here
# openai | anthropic | ollama (free, runs locally)
LLM_PROVIDER=openai
# openai: gpt-4o, gpt-4-turbo-preview
# anthropic: claude-sonnet-4-6 (needs Claude API subscription, not claude.ai)
# ollama: llama3.2, mistral, gemma3, … (run: ollama pull <model>)
LLM_MODEL=gpt-4-turbo-preview

# Embeddings Configuration
# Anthropic does not provide an embeddings API, so embeddings use a separate provider.
# openai (default, paid) | local (free, runs in-process)
EMBEDDINGS_PROVIDER=openai
# OpenAI key for embeddings.
#   Leave empty when LLM_PROVIDER=openai — LLM_API_KEY is reused.
#   Required when LLM_PROVIDER=anthropic and EMBEDDINGS_PROVIDER=openai.
#   Not used when EMBEDDINGS_PROVIDER=local.
EMBEDDINGS_API_KEY=
# EMBEDDINGS_PROVIDER=openai : text-embedding-3-small | text-embedding-3-large
# EMBEDDINGS_PROVIDER=local  : all-MiniLM-L6-v2 (fast, 384-dim)
#                              | all-mpnet-base-v2 (accurate, 768-dim)
EMBEDDING_MODEL=text-embedding-3-small
# Must match EMBEDDING_MODEL:
#   text-embedding-3-small → 1536
#   text-embedding-3-large → 3072
#   all-MiniLM-L6-v2       → 384
#   all-mpnet-base-v2      → 768
EMBEDDING_DIMENSION=1536

# Fully free setup (no API keys at all):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3.2
#   EMBEDDINGS_PROVIDER=local
#   EMBEDDING_MODEL=all-MiniLM-L6-v2
#   EMBEDDING_DIMENSION=384
#   pip install "bamboo[local]"   # installs langchain-ollama + sentence-transformers
#   ollama pull llama3.2          # pull the model (one-time, ~2GB)
#   ollama serve                  # keep running in a separate terminal

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
# Optional: leave empty for local/self-hosted Qdrant instance
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=bamboo_knowledge

# Application Settings
LOG_LEVEL=INFO
