# LLM Configuration
# OpenAI or Anthropic key — not required when LLM_PROVIDER=ollama
LLM_API_KEY=your_api_key_here
# openai | anthropic | ollama (free, runs locally)
LLM_PROVIDER=openai
# openai: gpt-4o, gpt-4-turbo-preview
# anthropic: claude-sonnet-4-6 (needs Claude API subscription, not claude.ai)
# ollama: llama3.2, mistral, gemma3, … (run: ollama pull <model>)
LLM_MODEL=gpt-4-turbo-preview

# Embeddings Configuration
# Anthropic does not provide an embeddings API, so embeddings use a separate provider.
# openai (default, paid) | local (free, runs in-process via sentence-transformers)
EMBEDDINGS_PROVIDER=openai

# OpenAI key for embeddings.
#   Leave empty when LLM_PROVIDER=openai — LLM_API_KEY is reused automatically.
#   Required when LLM_PROVIDER=anthropic and EMBEDDINGS_PROVIDER=openai.
#   Not used when EMBEDDINGS_PROVIDER=local.
EMBEDDINGS_API_KEY=

# EMBEDDING_MODEL and EMBEDDING_DIMENSION must match each other.
# Pick ONE block below and delete the other.
#
# ── Option A: OpenAI embeddings (EMBEDDINGS_PROVIDER=openai) ──────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
#
# ── Option B: local sentence-transformers (EMBEDDINGS_PROVIDER=local) ─────
# Uncomment the two lines below AND comment out Option A above.
# Also run: pip install "bamboo[local-embeddings]"
#EMBEDDING_MODEL=all-MiniLM-L6-v2
#EMBEDDING_DIMENSION=384
# HuggingFace token — optional but recommended when EMBEDDINGS_PROVIDER=local.
# Without it, model downloads are rate-limited by the HuggingFace Hub.
# Obtain a (free) token at https://huggingface.co/settings/tokens
#HF_TOKEN=

# Fully free setup (no API keys at all):
#   1. Set LLM_PROVIDER=ollama, LLM_MODEL=llama3.2
#   2. Set EMBEDDINGS_PROVIDER=local and use Option B above
#   3. pip install "bamboo[local]"
#   4. ollama pull llama3.2 && ollama serve
# Optional: To yield faster responses with less accurate reasoning (good for testing).
#OLLAMA_REASONING=false
# Optional: Ollama server URL (default http://localhost:11434). Also used to
# auto-detect the served context window — see LLM_CONTEXT_WINDOW below.
#OLLAMA_BASE_URL=http://localhost:11434

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
# Optional: leave empty for local/self-hosted Qdrant instance
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=bamboo_knowledge

# Application Settings
LOG_LEVEL=INFO

# Knowledge Review Gate
# An LLM reviewer evaluates each extracted graph before it is written to the
# databases.  On rejection the extractor retries with corrective feedback
# (up to 2 retries).  On the first rejection an Extra Source Explorer also fires,
# fetching additional data via the MCP tool layer to enrich the next attempt.
# Set to false to skip review and reduce LLM cost on routine accumulation runs.
#ENABLE_KNOWLEDGE_REVIEW=true

# External MCP Servers (optional)
# Path to a JSON file listing external MCP servers to expose to ExtraSourceExplorer.
# Requires the 'mcp' package: pip install "bamboo[external-mcp]"
# See docs/AGENTS.md for the expected JSON format.
#MCP_SERVERS_CONFIG=/path/to/mcp_servers.json

# Tool selection for large MCP catalogues (optional)
# When many external MCP tools are configured, the orchestration tool list is bounded
# two ways (see docs/AGENTS.md). The defaults are fine for the built-in PanDA tooling.
#
# Model context window in tokens. 0 = auto-detect (Ollama reads the *served* window
# from /api/ps; OpenAI/Anthropic use a built-in constant). Set a positive value to
# override, e.g. to match a specific Ollama num_ctx. Model-wide, not just tools.
#LLM_CONTEXT_WINDOW=0
# Tokens reserved for the model's response + headroom (subtracted from the window).
#TOOL_BUDGET_MARGIN=1024
# Relevance cap (primary knob): max tools rendered with a full JSON schema even when
# more would fit the window. The rest show as compact one-liners and stay callable —
# keeps tool-selection accurate and cheap on large catalogues.
#TOOL_MAX_FULL_SCHEMAS=25
# Advanced: retrieval ranking-pool size. 0 = auto = max(40, 3 x TOOL_MAX_FULL_SCHEMAS).
#TOOL_RETRIEVAL_CANDIDATE_K=0

# PanDA Client Configuration
# Uncomment and adjust these when pointing at a specific PanDA server.
# By default, panda-client-light uses the official CERN production server.
# See docs/PANDA_INTEGRATION.md for details.
#PANDA_URL_SSL=https://your.panda.server:25443/server/panda
#PANDA_URL=http://your.panda.server:25080/server/panda
#PANDA_AUTH=oidc
#PANDA_AUTH_VO=vo.role
#PANDA_USE_NATIVE_HTTPLIB=1
# Disables host verification for PanDA *data-plane* calls only. NOTE: this does
# NOT affect OIDC login (`@bamboo login`) — that path uses stdlib SSL. If login
# fails with "certificate verify failed: unable to get local issuer certificate",
# your Python has no CA trust store; set SSL_CERT_FILE below instead of disabling
# verification.
#PANDA_VERIFY_HOST=off

# CA trust store for stdlib SSL (used by OIDC login). On python.org framework
# builds the default trust store can be empty. `bamboo verify` sets this
# automatically to the bundled certifi roots when it detects an empty store;
# you can also set it by hand. Example:
#SSL_CERT_FILE=/path/to/site-packages/certifi/cacert.pem

# Mattermost Frontend (optional)
# The ops-facing chat bot. Read by the `bamboo serve-mattermost` process — NOT
# sent to the Mattermost server. Requires: pip install "bamboo[mattermost]"
# (and "bamboo[panda]" for per-user OIDC login). See docs/MATTERMOST.md.
#MATTERMOST_URL=https://mattermost.example.org
#MATTERMOST_TOKEN=your-bot-access-token
# Comma-separated channel IDs the bot will act in (empty = ignore everything):
#MATTERMOST_ALLOWED_CHANNELS=channelid1,channelid2
# Require per-user `login` (no fallback to the bot's service identity):
#MATTERMOST_REQUIRE_USER_LOGIN=false
# Where per-user OIDC tokens are stored (default ~/.bamboo/mattermost_tokens):
#MATTERMOST_TOKEN_DIR=

